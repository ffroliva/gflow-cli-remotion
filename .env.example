# Promo recording environment.
# Copy to .env.local (gitignored) and fill in. Only OBS_WS_PASSWORD is required
# for a real recording.

# OBS WebSocket password (Tools → WebSocket Server Settings in OBS).
OBS_WS_PASSWORD=""

# Optional: override the gflow profile-root lookup. Mainly for tests; operators
# rarely need this. Defaults to the platform gflow-cli data dir.
# GFLOW_PROFILE_ROOT=""
